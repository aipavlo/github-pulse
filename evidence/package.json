{
  "name": "github-pulse-evidence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "11.x"
  },
  "scripts": {
    "postinstall": "node ./scripts/patch-evidence-template.mjs",
    "prepare:duckdb": "node ./scripts/prepare-duckdb-cache.mjs",
    "dev": "node ./node_modules/@evidence-dev/evidence/cli.js dev",
    "build": "HOME=.evidence/home npm run prepare:duckdb && HOME=.evidence/home EVIDENCE_BUILD_DIR=build node ./node_modules/@evidence-dev/evidence/cli.js build",
    "preview": "node ./node_modules/@evidence-dev/evidence/cli.js preview",
    "sources": "HOME=.evidence/home npm run prepare:duckdb && HOME=.evidence/home node ./node_modules/@evidence-dev/evidence/cli.js sources",
    "build:pages": "npm run sources && npm run build",
    "build:strict": "HOME=.evidence/home npm run prepare:duckdb && HOME=.evidence/home EVIDENCE_BUILD_DIR=build node ./node_modules/@evidence-dev/evidence/cli.js build:strict"
  },
  "dependencies": {
    "@evidence-dev/component-utilities": "4.0.13",
    "@evidence-dev/core-components": "5.4.2",
    "@evidence-dev/duckdb": "2.0.1",
    "@evidence-dev/evidence": "40.1.8",
    "@evidence-dev/tailwind": "3.1.4"
  },
  "devDependencies": {
    "@sveltejs/kit": "2.8.4",
    "@sveltejs/vite-plugin-svelte": "3.1.2",
    "autoprefixer": "10.4.22",
    "debounce": "1.2.1",
    "git-remote-origin-url": "4.0.0",
    "postcss": "8.5.6",
    "postcss-load-config": "4.0.2",
    "svelte": "4.2.19",
    "svelte-preprocess": "5.1.3",
    "svelte2tsx": "0.7.4",
    "tailwindcss": "3.4.18",
    "typescript": "5.4.2",
    "unist-util-visit": "4.1.2",
    "vite": "5.4.21"
  },
  "overrides": {
    "cookie": "1.1.1",
    "minimatch": "10.2.5",
    "prismjs": "1.30.0",
    "trim": "1.0.1"
  }
}
